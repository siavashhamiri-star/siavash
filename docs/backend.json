
{
    "entities": {
        "UserProfile": {
            "title": "User Profile",
            "description": "Represents a user's profile in the system.",
            "type": "object",
            "properties": {
                "displayName": { "type": "string" },
                "email": { "type": "string", "format": "email" },
                "photoURL": { "type": "string", "format": "uri" },
                "isVendor": { "type": "boolean" },
                "vendorId": { "type": "string" },
                "adCount": { "type": "number", "description": "Number of free ads used this month." }
            },
            "required": ["displayName", "email"]
        },
        "Handicraft": {
            "title": "Handicraft",
            "description": "An advertisement for an Iranian handicraft.",
            "type": "object",
            "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" },
                "price": { "type": "string" },
                "category": { "type": "string", "enum": ["kilim", "jajim", "silver", "antique", "painting", "other"] },
                "imageUrl": { "type": "string", "format": "uri" },
                "userId": { "type": "string" },
                "userName": { "type": "string" },
                "nationalCode": { "type": "string" },
                "createdAt": { "type": "object" },
                "isPremiumDesign": { "type": "boolean" }
            },
            "required": ["title", "description", "price", "category", "userId", "userName", "createdAt"]
        },
        "Vendor": {
            "title": "Vendor",
            "description": "Represents a vendor in the system.",
            "type": "object",
            "properties": {
                "name": { "type": "string" },
                "location": { "type": "string" },
                "bio": { "type": "string" },
                "specialties": { "type": "array", "items": { "type": "string" } },
                "avatarUrl": { "type": "string", "format": "uri" },
                "userId": { "type": "string" },
                "isVerified": { "type": "boolean" }
            },
            "required": ["name", "location", "bio", "userId"]
        },
        "Carpet": {
            "title": "Carpet",
            "description": "Represents a carpet in the system.",
            "type": "object",
            "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "price": { "type": "string" },
                "imageUrl": { "type": "string", "format": "uri" },
                "vendorId": { "type": "string" },
                "consignment": { "type": "boolean" }
            },
            "required": ["name", "description", "price", "imageUrl", "vendorId"]
        }
    },
    "auth": {
        "providers": ["anonymous", "google.com", "github.com", "password"]
    },
    "firestore": {
        "/users/{userId}": {
            "schema": { "$ref": "#/backend/entities/UserProfile" },
            "description": "Stores user profiles."
        },
        "/handicrafts/{id}": {
            "schema": { "$ref": "#/backend/entities/Handicraft" },
            "description": "Stores handicraft advertisements."
        },
        "/vendors/{vendorId}": {
            "schema": { "$ref": "#/backend/entities/Vendor" },
            "description": "Stores vendor information."
        },
        "/vendors/{vendorId}/carpets/{carpetId}": {
            "schema": { "$ref": "#/backend/entities/Carpet" },
            "description": "Stores carpets for a vendor."
        }
    }
}
