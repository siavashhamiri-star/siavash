
{
    "entities": {
        "UserProfile": {
            "title": "User Profile",
            "description": "Represents a user's profile in the system.",
            "type": "object",
            "properties": {
                "displayName": { "type": "string" },
                "email": { "type": "string", "format": "email" },
                "photoURL": { "type": "string", "format": "uri" },
                "isVendor": { "type": "boolean" },
                "vendorId": { "type": "string" },
                "adCount": { "type": "number", "description": "Number of free ads used this month." }
            },
            "required": ["displayName", "email"]
        },
        "Handicraft": {
            "title": "Handicraft",
            "description": "An advertisement for an Iranian handicraft.",
            "type": "object",
            "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" },
                "price": { "type": "string" },
                "category": { "type": "string", "enum": ["kilim", "jajim", "silver", "antique", "painting", "other"] },
                "imageUrl": { "type": "string", "format": "uri" },
                "userId": { "type": "string" },
                "userName": { "type": "string" },
                "nationalCode": { "type": "string" },
                "createdAt": { "type": "object" },
                "isPremiumDesign": { "type": "boolean" }
            },
            "required": ["title", "description", "price", "category", "userId", "userName", "createdAt"]
        },
        "AppraisalRequest": {
            "title": "Appraisal Request",
            "description": "A request for expert carpet valuation.",
            "type": "object",
            "properties": {
                "carpetName": { "type": "string" },
                "dimensions": { "type": "string" },
                "origin": { "type": "string" },
                "age": { "type": "string" },
                "imageDataUri": { "type": "string" },
                "userId": { "type": "string" },
                "status": { "type": "string", "enum": ["pending", "paid", "completed"] },
                "createdAt": { "type": "object" }
            },
            "required": ["carpetName", "userId", "status"]
        }
    },
    "auth": {
        "providers": ["anonymous", "google.com", "github.com", "password"]
    },
    "firestore": {
        "/users/{userId}": {
            "schema": { "$ref": "#/backend/entities/UserProfile" }
        },
        "/handicrafts/{id}": {
            "schema": { "$ref": "#/backend/entities/Handicraft" }
        },
        "/appraisals/{id}": {
            "schema": { "$ref": "#/backend/entities/AppraisalRequest" }
        }
    }
}
