rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // By default, deny all reads and writes.
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }

    match /vendors/{vendorId} {
      allow read: if true;
      // Allow creating a vendor profile if the user is authenticated and the vendor's userId matches their own.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Allow updates only by the user who owns the vendor profile.
      allow update: if request.auth != null && get(/databases/$(database)/documents/vendors/$(vendorId)).data.userId == request.auth.uid;
    }

    match /vendors/{vendorId}/carpets/{carpetId} {
        allow read: if true;
        allow write: if request.auth != null && get(/databases/$(database)/documents/vendors/$(vendorId)).data.userId == request.auth.uid;
    }

    match /vendors/{vendorId}/reviews/{reviewId} {
        allow read: if true;
        // Allow creating a review if the user is authenticated and the review's userId matches their own.
        // A user cannot review their own vendor profile.
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && get(/databases/$(database)/documents/vendors/$(vendorId)).data.userId != request.auth.uid;
    }
  }
}
